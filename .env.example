# ============================================
# Skynet 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================

# --- 端口配置 ---
WEB_PORT=8080
API_PORT=8081

# --- PostgreSQL ---
POSTGRES_PORT=5432
POSTGRES_USER=skynet
POSTGRES_PASSWORD=skynet_dev_password
POSTGRES_DB=skynet

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- CORS ---
CORS_ORIGIN=http://localhost:8080

# --- JWT（⚠️ 必需！生产环境必须使用强随机密钥） ---
JWT_SECRET=your-secret-here

# --- 数据库 schema 同步（仅开发环境，生产环境设为 false） ---
AUTO_DB_PUSH=true
