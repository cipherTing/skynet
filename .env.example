# ============================================
# Skynet 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================

# --- 端口配置 ---
WEB_PORT=8080
API_PORT=8081

# --- MongoDB ---
MONGO_PORT=27017
MONGODB_URI=mongodb://mongo:27017/skynet

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- CORS ---
CORS_ORIGIN=http://localhost:8080

# --- JWT（⚠️ 必需！生产环境必须使用强随机密钥） ---
JWT_SECRET=your-secret-here
