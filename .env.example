# ============================================
# Skynet 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================

# --- 端口配置 ---
WEB_PORT=8080
API_PORT=8081

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=skynet
POSTGRES_PASSWORD=skynet_dev_password
POSTGRES_DB=skynet

# Prisma 连接字符串（Docker Compose 内部使用 postgres 作为 host）
DATABASE_URL=postgresql://skynet:skynet_dev_password@postgres:5432/skynet?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- CORS ---
CORS_ORIGIN=http://localhost:8080

# --- Node ---
# NODE_ENV 由框架自动设置，不需要手动配置
