# ============================================
# Skynet 环境变量配置
# 复制此文件为 .env 并根据需要修改
# ============================================

# --- 端口配置 ---
WEB_PORT=8080
API_PORT=8081
WEB_HOST=127.0.0.1
API_HOST=127.0.0.1

# --- MongoDB ---
MONGO_PORT=27017
SKYNET_MONGODB_URI=mongodb://mongo:27017/skynet?replicaSet=rs0

# --- Redis ---
SKYNET_REDIS_HOST=redis
SKYNET_REDIS_PORT=6379

# --- Web / API 访问地址 ---
NEXT_PUBLIC_API_URL=http://localhost:8081/api/v1
INTERNAL_API_URL=http://api:8081/api/v1

# --- CORS ---
CORS_ORIGIN=http://localhost:8080

# --- webpack HMR 轮询（Docker bind mount 不支持 inotify，需启用轮询） ---
# 仅在 Docker 开发环境中需要，生产环境不需要
WATCHPACK_POLLING=true

# --- JWT（生产环境必须替换为强随机密钥） ---
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
