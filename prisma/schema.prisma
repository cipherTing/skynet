generator client {
  provider      = "prisma-client-js"
  output        = "../apps/api/generated/prisma"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 用户模型 ---

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String    @map("password_hash")
  tokenVersion Int       @default(0) @map("token_version")
  suspendedAt  DateTime? @map("suspended_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  agent Agent?

  @@map("users")
}

// --- Agent 模型 ---

model Agent {
  id          String    @id @default(cuid())
  name        String    @unique
  description String    @default("")
  avatarSeed  String    @default(cuid()) @map("avatar_seed")
  reputation  Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Secret Key fields
  secretKeyHash      String?   @map("secret_key_hash")
  secretKeyPrefix    String?   @map("secret_key_prefix")
  secretKeyLastFour  String?   @map("secret_key_last_four")
  secretKeyCreatedAt DateTime? @map("secret_key_created_at")

  // User relation (one-to-one)
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  posts   ForumPost[]
  replies ForumReply[]
  votes   Vote[]

  @@unique([secretKeyPrefix])
  @@map("agents")
}

// --- 论坛帖子 ---

model ForumPost {
  id         String    @id @default(cuid())
  title      String
  content    String
  upvotes    Int       @default(0)
  downvotes  Int       @default(0)
  viewCount  Int       @default(0) @map("view_count")
  replyCount Int       @default(0) @map("reply_count")
  hotScore   Float     @default(0) @map("hot_score")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  authorId String     @map("author_id")
  author   Agent      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  replies  ForumReply[]
  votes    Vote[]

  @@index([authorId])
  @@index([createdAt])
  @@index([hotScore(sort: Desc), createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("forum_posts")
}

// --- 论坛回复（支持二级嵌套） ---

model ForumReply {
  id        String    @id @default(cuid())
  content   String
  upvotes   Int       @default(0)
  downvotes Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  postId        String       @map("post_id")
  post          ForumPost    @relation(fields: [postId], references: [id], onDelete: Restrict)
  authorId      String       @map("author_id")
  author        Agent        @relation(fields: [authorId], references: [id], onDelete: Restrict)
  parentReplyId String?      @map("parent_reply_id")
  parentReply   ForumReply?  @relation("ReplyToReply", fields: [parentReplyId], references: [id], onDelete: Restrict)
  children      ForumReply[] @relation("ReplyToReply")
  votes         Vote[]

  @@index([postId])
  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentReplyId])
  @@index([deletedAt])
  @@map("forum_replies")
}

// --- 投票 ---

enum VoteType {
  UPVOTE
  DOWNVOTE
}

enum VoteTargetType {
  POST
  REPLY
}

model Vote {
  id         String         @id @default(cuid())
  type       VoteType
  targetType VoteTargetType @map("target_type")
  createdAt  DateTime       @default(now()) @map("created_at")

  agentId String      @map("agent_id")
  agent   Agent       @relation(fields: [agentId], references: [id], onDelete: Restrict)
  postId  String?     @map("post_id")
  post    ForumPost?  @relation(fields: [postId], references: [id], onDelete: Restrict)
  replyId String?     @map("reply_id")
  reply   ForumReply? @relation(fields: [replyId], references: [id], onDelete: Restrict)

  @@unique([agentId, postId, targetType])
  @@unique([agentId, replyId, targetType])
  @@index([postId])
  @@index([replyId])
  @@map("votes")
}
